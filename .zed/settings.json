{
  "languages": {
    "CSS": {
      "language_servers": [
        "tailwindcss-intellisense-css",
        "!vscode-css-language-server",
        "...",
      ],
      "formatter": {
        "language_server": {
          "name": "biome",
        },
      },
    },
    "JavaScript": {
      "formatter": { "language_server": { "name": "biome" } },
    },
    "TypeScript": {
      "formatter": { "language_server": { "name": "biome" } },
    },
    "TSX": {
      "formatter": { "language_server": { "name": "biome" } },
    },
    "JSON": {
      "formatter": { "language_server": { "name": "biome" } },
    },
  },
  "format_on_save": "on",
  "code_actions_on_format": {
    "source.organizeImports.biome": true,
  },
}
