{
	"compilerOptions": {
		"allowImportingTsExtensions": true,
		"esModuleInterop": true,
		"forceConsistentCasingInFileNames": true,
		"module": "Node16",
		"moduleResolution": "Node16",
		"noEmit": true,
		"rewriteRelativeImportExtensions": true,
		"rootDir": ".",
		"skipLibCheck": true,
		"strict": true,
		"target": "ES2022",
		"verbatimModuleSyntax": true
	},
	"include": ["src/**/*"],
	"exclude": ["node_modules", "dist"]
}
